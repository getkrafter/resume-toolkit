{
  "name": "@getkrafter/resume-toolkit",
  "version": "0.0.0-development",
  "description": "Deterministic resume scoring, ATS keyword matching, and guided resume improvement",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "bin": {
    "resume-toolkit": "bin/cli.sh"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "node scripts/stamp-skill-versions.js",
    "postinstall": "node scripts/check-skill-versions.js || true"
  },
  "keywords": [
    "resume",
    "ats",
    "scoring",
    "mcp",
    "ai",
    "skills",
    "interview",
    "improvement"
  ],
  "author": "Muhammad Kasim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getkrafter/resume-toolkit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "natural": {
      "dotenv": "16.4.7"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "natural": "~8.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
